    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end
    local char = Player.Character
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 16
        end
    end
end)

addSlider(moveTab, "TỐC ĐỘ", 16, 200, 50, function(v)
