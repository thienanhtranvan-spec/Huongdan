local function createNameHp(player)
    if player == LocalPlayer then return end
    
    local gui = Instance.new("BillboardGui")
    gui.Name = "ESP_" .. player.Name
    gui.Size = UDim2.new(0, 150, 0, 40)
    gui.StudsOffset = Vector3.new(0, 2.5, 0)
    gui.AlwaysOnTop = true
    gui.Parent = player.Character and player.Character:FindFirstChild("Head") or nil
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 18)
    nameLabel.Position = UDim2.new(0, 0, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(0, 150, 255)
    nameLabel.TextSize = 12
    nameLabel.TextStrokeTransparency = 0.3
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = gui
    
    local hpBarBg = Instance.new("Frame")
    hpBarBg.Size = UDim2.new(1, -20, 0, 4)
    hpBarBg.Position = UDim2.new(0, 10, 0, 20)
    hpBarBg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    hpBarBg.BorderSizePixel = 0
    hpBarBg.Parent = gui
    
    local hpBarCorner = Instance.new("UICorner")
    hpBarCorner.CornerRadius = UDim.new(0, 2)
    hpBarCorner.Parent = hpBarBg
    
    local hpBar = Instance.new("Frame")
    hpBar.Size = UDim2.new(1, 0, 1, 0)
    hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    hpBar.BorderSizePixel = 0
    hpBar.Parent = hpBarBg
    
    local hpBarFillCorner = Instance.new("UICorner")
    hpBarFillCorner.CornerRadius = UDim.new(0, 2)
    hpBarFillCorner.Parent = hpBar
    
    local hpText = Instance.new("TextLabel")
    hpText.Size = UDim2.new(1, 0, 0, 12)
    hpText.Position = UDim2.new(0, 0, 0, 25)
    hpText.BackgroundTransparency = 1
    hpText.Text = "100"
    hpText.TextColor3 = Color3.fromRGB(255, 255, 255)
    hpText.TextSize = 9
    hpText.Font = Enum.Font.Gotham
    hpText.Parent = gui
    
    espGui[player] = {gui = gui, hpBar = hpBar, hpText = hpText}
    
    local function updateHp()
        local char = player.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                local hp = humanoid.Health
                local maxHp = humanoid.MaxHealth
                local percent = math.clamp(hp / maxHp, 0, 1)
                hpBar.Size = UDim2.new(percent, 0, 1, 0)
                hpText.Text = math.floor(hp) .. "/" .. math.floor(maxHp)
                
                if percent > 0.6 then
                    hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                elseif percent > 0.3 then
                    hpBar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                else
                    hpBar.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                end
            end
        end
    end
    
    updateHp()
    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        gui.Parent = player.Character and player.Character:FindFirstChild("Head")
        updateHp()
    end)
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not player.Character or not player.Character.Parent then
            if gui then gui:Destroy() end
            if connection then connection:Disconnect() end
            return
        end
        updateHp()
    end)
end

local function createOutline(player)
    if player == LocalPlayer then return end
    
    local function addOutline(character)
        if not character then return end
        
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                if not outlineInstances[part] then
                    local highlight = Instance.new("Highlight")
                    highlight.Parent = part
                    highlight.Adornee = part
                    highlight.FillTransparency = 1
                    highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                    highlight.OutlineTransparency = 0
                    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    
                    local glow = Instance.new("BillboardGui")
                    glow.Size = UDim2.new(0, part.Size.X * 10, 0, part.Size.Y * 10)
                    glow.AlwaysOnTop = true
                    glow.LightInfluence = 0
                    glow.Parent = part
                    
                    local frame = Instance.new("Frame")
                    frame.Size = UDim2.new(1, 0, 1, 0)
                    frame.BackgroundTransparency = 0.7
                    frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                    frame.BorderSizePixel = 0
                    frame.Parent = glow
                    
                    outlineInstances[part] = {highlight = highlight, glow = glow}
                end
            end
        end
    end
    
    local character = player.Character
    if character then
        addOutline(character)
        
        character.DescendantAdded:Connect(function(part)
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and not outlineInstances[part] then
                addOutline(part)
            end
        end)
    end
    
    player.CharacterAdded:Connect(function(newChar)
        task.wait(0.5)
        for _, data in pairs(outlineInstances) do
            if data.highlight then data.highlight:Destroy() end
            if data.glow then data.glow:Destroy() end
        end
        outlineInstances = {}
        addOutline(newChar)
        
        newChar.DescendantAdded:Connect(function(part)
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and not outlineInstances[part] then
                addOutline(part)
            end
        end)
    end)
end

local function removeESP(player)
    if espGui[player] then
        if espGui[player].gui then espGui[player].gui:Destroy() end
        espGui[player] = nil
    end
    
    if outlineInstances then
        for part, data in pairs(outlineInstances) do
            if data.highlight then data.highlight:Destroy() end
            if data.glow then data.glow:Destroy() end
        end
        outlineInstances = {}
    end
end

local function toggleNameHp()
    espEnabled.nameHp = not espEnabled.nameHp
    updateNameHpButton()
    
    if espEnabled.nameHp then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and not espGui[player] then
                createNameHp(player)
            end
        end
    else
        for _, player in pairs(Players:GetPlayers()) do
            removeESP(player)
            if espEnabled.outline then
                createOutline(player)
            end
        end
    end
end

local function toggleOutline()
    espEnabled.outline = not espEnabled.outline
    updateOutlineButton()
    
    if espEnabled.outline then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                createOutline(player)
            end
        end
    else
        for _, data in pairs(outlineInstances) do
            if data.highlight then data.highlight:Destroy() end
            if data.glow then data.glow:Destroy() end
        end
        outlineInstances = {}
    end
end

